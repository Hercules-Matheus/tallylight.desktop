{
  "name": "tally-desktop",
  "version": "1.1.0",
  "description": "Sistema de Tally para ATEM Blackmagic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-frontend": "cd frontend && npm run build",
    "pre-dist": "npm run build-frontend",
    "clean": "rimraf dist",
    "dist": "npm run clean && electron-builder",
    "release": "npm run pre-dist && npm run dist"
  },
  "build": {
    "appId": "com.vvp.tally",
    "productName": "TallyControl",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "files": [
      "**/*",
      "!frontend/src",
      "!frontend/public",
      "!frontend/node_modules",
      "!dist"
    ],
    "asar": true
  },
  "dependencies": {
    "atem-connection": "^3.9.0",
    "express": "^4.22.1",
    "nosleep.js": "^0.12.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
